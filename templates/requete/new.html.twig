{% extends 'base.html.twig' %}

{% block title %}Faire une requête{% endblock %}

{% block body %}
    <section style="max-width: 720px; margin: 40px auto; padding: 0 16px;">
        <h1>Faire une requête</h1>

        {% for message in app.flashes('success') %}
            <p style="color: #166534;">{{ message }}</p>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <p style="color: #b91c1c;">{{ message }}</p>
        {% endfor %}

        {{ form_start(form) }}
        {{ form_row(form.titre) }}
        {{ form_row(form.categorie) }}
        {{ form_row(form.dateSouhaitee) }}
        {{ form_row(form.description) }}

        <button type="submit">Envoyer la requête</button>
        {{ form_end(form) }}
    </section>
{% endblock %}
