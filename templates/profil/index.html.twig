{% extends 'base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block body %}
<style>
    .profil-page {
        min-height: calc(100vh - 96px);
        display: grid;
        place-items: center;
        padding: 2rem 1rem;
        background: #f5f7fb;
    }

    .profil-card {
        width: 100%;
        max-width: 430px;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        background: #fff;
        box-shadow: 0 15px 30px rgba(15, 23, 42, 0.08);
        padding: 2rem;
    }

    .profil-title {
        margin: 0;
        color: #0f172a;
        font-size: 2rem;
        line-height: 1.1;
    }

    .profil-subtitle {
        margin: 0.5rem 0 1.4rem;
        color: #64748b;
    }

    .profil-form {
        display: grid;
        gap: 1rem;
    }

    .profil-label {
        display: block;
        margin-bottom: 0.4rem;
        color: #334155;
        font-weight: 600;
    }

    .profil-input {
        width: 100%;
        border: 1px solid #cbd5e1;
        border-radius: 12px;
        padding: 0.75rem 0.9rem;
        font-size: 1rem;
        outline: none;
    }

    .profil-input:focus {
        border-color: var(--color-bleu);
        box-shadow: 0 0 0 3px rgba(27, 71, 93, 0.14);
    }

    .profil-btn {
        border: 0;
        border-radius: 12px;
        padding: 0.75rem 1rem;
        color: #fff;
        font-weight: 700;
        cursor: pointer;
        background: var(--color-bleu);
    }

    .profil-btn:hover {
        opacity: 0.92;
    }

    .profil-error {
        border: 1px solid #fecaca;
        background: #fef2f2;
        color: #b91c1c;
        border-radius: 12px;
        padding: 0.7rem 0.85rem;
        margin-bottom: 1rem;
        font-size: 0.95rem;
    }

    .profil-success {
        border: 1px solid #bbf7d0;
        background: #f0fdf4;
        color: #166534;
        border-radius: 12px;
        padding: 0.7rem 0.85rem;
        margin-bottom: 1rem;
        font-size: 0.95rem;
    }

    .profil-form>div {
        margin: 0;
    }

    .profil-form ul {
        margin: 0.35rem 0 0;
        padding-left: 1rem;
        color: #b91c1c;
        font-size: 0.9rem;
    }

    .profil-footer {
        margin-top: 1.25rem;
        color: #475569;
        text-align: center;
    }

    .profil-footer a {
        color: #0f172a;
        font-weight: 600;
    }
</style>

<section class="profil-page">
    <div class="profil-card">
        <h1 class="profil-title">Gestion du profil</h1>
        <p class="profil-subtitle">Modifiez vos informations personnelles.</p>

        {% for message in app.flashes('success') %}
        <div class="profil-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
        <div class="profil-error">{{ message }}</div>
        {% endfor %}

        {% if currentAvatar %}
        <div style="margin-bottom: 1rem; text-align:center;">
            <img src="{{ asset('uploads/avatars/' ~ currentAvatar) }}" alt="Avatar actuel"
                style="width:80px;height:80px;border-radius:999px;object-fit:cover;">
        </div>
        {% endif %}

        {{ form_start(profilForm, { attr: { class: 'profil-form' } }) }}
        {{ form_row(profilForm.nom, {
        label_attr: { class: 'profil-label' },
        attr: { class: 'profil-input' }
        }) }}
        {{ form_row(profilForm.prenom, {
        label_attr: { class: 'profil-label' },
        attr: { class: 'profil-input' }
        }) }}
        {{ form_row(profilForm.email, {
        label_attr: { class: 'profil-label' },
        attr: { class: 'profil-input' }
        }) }}
        {{ form_row(profilForm.avatarFile, {
        label_attr: { class: 'profil-label' },
        attr: { class: 'profil-input' }
        }) }}
        {{ form_row(profilForm.plainPassword.first, {
        label_attr: { class: 'profil-label' },
        attr: { class: 'profil-input' }
        }) }}
        {{ form_row(profilForm.plainPassword.second, {
        label_attr: { class: 'profil-label' },
        attr: { class: 'profil-input' }
        }) }}

        <button class="profil-btn" type="submit">Enregistrer</button>
        {{ form_end(profilForm) }}

    </div>
</section>

{% endblock %}