{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
    <style>
        .login-page {
            min-height: calc(100vh - 96px);
            display: grid;
            place-items: center;
            padding: 2rem 1rem;
            background: #f5f7fb;
        }

        .login-card {
            width: 100%;
            max-width: 430px;
            border: 1px solid #e2e8f0;
            border-radius: 18px;
            background: #fff;
            box-shadow: 0 15px 30px rgba(15, 23, 42, 0.08);
            padding: 2rem;
        }

        .login-title {
            margin: 0;
            color: #0f172a;
            font-size: 2rem;
            line-height: 1.1;
        }

        .login-subtitle {
            margin: 0.5rem 0 1.4rem;
            color: #64748b;
        }

        .login-form {
            display: grid;
            gap: 1rem;
        }

        .login-label {
            display: block;
            margin-bottom: 0.4rem;
            color: #334155;
            font-weight: 600;
        }

        .login-input {
            width: 100%;
            border: 1px solid #cbd5e1;
            border-radius: 12px;
            padding: 0.75rem 0.9rem;
            font-size: 1rem;
            outline: none;
        }

        .login-input:focus {
            border-color: var(--color-bleu);
            box-shadow: 0 0 0 3px rgba(27, 71, 93, 0.14);
        }

        .login-btn {
            border: 0;
            border-radius: 12px;
            padding: 0.75rem 1rem;
            color: #fff;
            font-weight: 700;
            cursor: pointer;
            background: var(--color-bleu);
        }

        .login-btn:hover {
            opacity: 0.92;
        }

        .login-help {
            margin-top: -0.3rem;
            text-align: right;
        }

        .login-help a {
            color: #334155;
            font-size: 0.92rem;
            text-decoration: none;
        }

        .login-help a:hover {
            text-decoration: underline;
        }

        .login-error {
            border: 1px solid #fecaca;
            background: #fef2f2;
            color: #b91c1c;
            border-radius: 12px;
            padding: 0.7rem 0.85rem;
            margin-bottom: 1rem;
            font-size: 0.95rem;
        }

        .login-footer {
            margin-top: 1.25rem;
            color: #475569;
            text-align: center;
        }

        .login-footer a {
            color: #0f172a;
            font-weight: 600;
        }
    </style>

    <section class="login-page">
        <div class="login-card">
            <h1 class="login-title">Connexion</h1>
            <p class="login-subtitle">Accédez à votre espace.</p>

            {% if error %}
                <div class="login-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            {% if app.user %}
                <p class="login-subtitle">Connecté en tant que {{ app.user.userIdentifier }}.</p>
                <form method="post" action="{{ path('app_logout') }}" class="login-form">
                    <button class="login-btn" type="submit">Se déconnecter</button>
                </form>
            {% else %}
                <form method="post" class="login-form">
                    <div>
                        <label for="username" class="login-label">Email</label>
                        <input class="login-input" type="email" id="username" name="_username" value="{{ last_username }}" required autocomplete="email">
                    </div>

                    <div>
                        <label for="password" class="login-label">Mot de passe</label>
                        <input class="login-input" type="password" id="password" name="_password" required autocomplete="current-password">
                    </div>
                    <div class="login-help">
                        <a href="{{ path('app_forgot_password_request') }}">Mot de passe oublié ?</a>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button class="login-btn" type="submit">Se connecter</button>
                </form>
            {% endif %}

            <p class="login-footer"><a href="{{ path('app_register') }}">Créer un compte</a></p>
        </div>
    </section>
{% endblock %}
